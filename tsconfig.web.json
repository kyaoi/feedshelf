{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowJs": false,
    "checkJs": false,
    "allowImportingTsExtensions": false,
    "module": "none",
    "types": [],
    "rootDir": "src/web",
    "outDir": "public/assets",
    "resolveJsonModule": false,
    "moduleDetection": "auto"
  },
  "include": [
    "src/web/app.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public/data"
  ]
}
