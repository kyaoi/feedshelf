{
  "name": "feedshelf",
  "private": true,
  "version": "0.1.0",
  "description": "FeedShelf internal pipeline entrypoint",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
