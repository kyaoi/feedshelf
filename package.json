{
  "name": "feedshelf",
  "private": true,
  "version": "0.1.0",
  "description": "FeedShelf internal pipeline entrypoint",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile=false",
    "pipeline:run": "tsx scripts/pipeline/run.js",
    "lint": "tsx scripts/lint.ts",
    "test": "tsx --test tests/*.test.ts",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run verify:web-ui",
    "typecheck": "tsc --noEmit",
    "build:web-ui": "tsc -p tsconfig.web.json",
    "build": "pnpm run build:web-ui",
    "verify:web-ui": "tsx scripts/verifyWebBuild.ts"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
