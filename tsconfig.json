{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.js",
    "tests/**/*.js",
    "public/assets/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public/data"
  ]
}
